{
  "manifest_version": 3,
  "name": "产品数据迁移助手",
  "version": "0.1.0",
  "description": "携程国内版VBK产品数据导出，导入到Trip.com国际版VBK",
  "permissions": [
    "storage",
    "activeTab"
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "background": {
    "service_worker": "background/service-worker.js"
  },
  "action": {
    "default_popup": "popup/popup.html",
    "default_title": "产品数据迁移助手",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "content_scripts": [
    {
      "matches": [
        "https://vbooking.ctrip.com/ivbk/vendor/baseInfoMerge*",
        "http://vbooking.ctrip.com/ivbk/vendor/baseInfoMerge*"
      ],
      "js": [
        "content/safe-storage.js",
        "content/antd1-filler.js",
        "content/react-filler.js",
        "content/page-detector.js",
        "content/form-extractor.js",
        "content/form-filler.js",
        "content/export.js",
        "content/import.js",
        "content/panel.js",
        "content/main.js"
      ],
      "css": [
        "content/injected-styles.css"
      ],
      "run_at": "document_idle"
    }
  ]
}
